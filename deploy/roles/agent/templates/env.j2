# .env - 由 Ansible 自动生成，仅存放敏感 Secret
# 路径: deploy/roles/agent/templates/env.j2

DISCORD_BOT_TOKEN={{ discord_bot_token | default('') }}
FINNHUB_API_KEY={{ finnhub_api_key | default('') }}
DEEPL_API_KEY={{ deepl_api_key | default('') }}
FRED_API_KEY={{ fred_api_key | default('') }}
JINA_API_KEY={{ jina_api_key | default('') }}

# ── LLM API Keys (从 ai_engines 嵌套字典提取) ──
GEMINI_API_KEY={{ ai_engines.api_key_gemeni | default('') }}
NVIDIA_API_KEY={{ ai_engines.api_key_nvidia | default('') }}
CLAUDE_API_KEY={{ ai_engines.api_key_claude | default('') }}

# 基础设施注入 (核心桥梁)
SENTINEL_ROOT={{ sentinel_path }}
SENTINEL_PREFIX={{ sentinel_prefix }}
SENTINEL_DOMAIN={{ domain }}
SENTINEL_WEB_BASE={{ web_base }}
HUGO_PATH={{ hugo_path }}

